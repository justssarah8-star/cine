CREATE TABLE empleados (id VARCHAR(10) PRIMARY KEY, correo VARCHAR(100) NOT NULL UNIQUE, contrasena VARCHAR(255) NOT NULL CHECK (length(contrasena) >= 8), rol VARCHAR(30) NOT NULL DEFAULT 'empleado_ventas' CHECK (rol IN ('administrador','empleado_ventas','operador')), creado_en TIMESTAMP DEFAULT NOW());

