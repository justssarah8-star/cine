CREATE TABLE horarios (
  id          SERIAL PRIMARY KEY,
  pelicula_id INT  NOT NULL,
  hora        TIME NOT NULL,
  sala        VARCHAR(20) DEFAULT 'Sala 1',
  FOREIGN KEY (pelicula_id) REFERENCES peliculas(id) ON DELETE CASCADE
);


CREATE VIEW vista_cartelera AS
SELECT
  p.id,
  p.titulo,
  p.genero,
  p.descripcion,
  STRING_AGG(h.hora::TEXT, ', ' ORDER BY h.hora) AS horarios,
  p.activo
FROM peliculas p
LEFT JOIN horarios h ON h.pelicula_id = p.id
GROUP BY p.id, p.titulo, p.genero, p.descripcion, p.activo;
